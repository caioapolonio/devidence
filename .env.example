# Copie para .env.local. O .env.local é ignorado pelo Git.

# OAuth App do GitHub — https://github.com/settings/developers > New OAuth App
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cifra o cookie de sessão. Mínimo de 32 caracteres.
# Gere com: openssl rand -base64 32
SESSION_SECRET=

# Origem pública da aplicação. Usada para montar o redirect do OAuth.
APP_URL=http://localhost:3000
