# Copy to .env.local. .env.local is ignored by Git.

# GitHub OAuth App: https://github.com/settings/developers > New OAuth App
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Encrypts the session cookie. At least 32 characters.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=

# Public origin of the app. Used to build the OAuth redirect.
APP_URL=http://localhost:3000
